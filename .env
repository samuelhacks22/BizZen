# Variables de Entorno para Expo y Android Studio
# Nota: Para que las variables estén disponibles en el código de tu app web/móvil,
# deben comenzar con el prefijo EXPO_PUBLIC_

# Ejemplo de URL de una API backend:
EXPO_PUBLIC_API_URL=https://api.tudominio.com

# Ejemplo de clave pública para algún servicio (ej. Firebase, Supabase, Stripe)
EXPO_PUBLIC_ANALYTICS_KEY=tu_clave_publica_aqui

# ----------------------------------------------------------------------
# Configuración interna para Android Studio / Construcciones Locales
# (Estas NO llevarán el prefijo EXPO_PUBLIC_ ya que son solo para el build)

# Ejemplo para definir rutas específicas del SDK si fuera necesario (opcional)
# ANDROID_HOME=C:\Users\tu_usuario\AppData\Local\Android\Sdk
